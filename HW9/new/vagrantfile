Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"

  config.vm.define "web" do |web|
    # Настройка сети (мост)
    web.vm.network "public_network"

    # Настройки ресурсов (CPU и RAM)
    web.vm.provider "virtualbox" do |vb|
      vb.memory = "2048"
      vb.cpus = 2
    end
        # Скрипт установки Java 21 и Maven
    web.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y openjdk-21-jdk maven
   #install petclinik      
pathpet=/home/pet
mkdir $pathpet
cd $pathpet
git clone https://github.com/spring-projects/spring-petclinic

cd $pathpet/spring-petclinic
mvn package

cat <<EOF > /etc/systemd/system/petclinic.service

[Unit]
Description=Spring PetClinic Application
After=network.target postgresql.service

[Service]
User=root
Group=root
WorkingDirectory=/home/pet/
Environment="POSTGRES_URL=jdbc:postgresql://192.168.31.51:5432/app_db"
Environment="POSTGRES_USER=app"
Environment="POSTGRES_PASS=secure_password_123"
ExecStart=/usr/bin/java -jar /home/pet/spring-petclinic/target/spring-petclinic-4.0.0-SNAPSHOT.jar --spring.profiles.active=postgres
SuccessExitStatus=143
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target

EOF

systemctl daemon-reload
systemctl enable --now petclinic
systemctl status petclinic
    SHELL

  end

 # Машина 2: PostgreSQL
  config.vm.define "db" do |db|
    db.vm.network "public_network"
    db.vm.provision "shell", inline: <<-SHELL
      apt-get update
      # Исправлено имя пакета (postgresql)
      apt-get install -y postgresql postgresql-contrib
      systemctl enable postgresql
      systemctl start postgresql
#!/bin/bash

# Настройки (измените под свои нужды)
DB_NAME="app_db"
DB_USER="app"
DB_PASS="secure_password_123"

# 1. Установка PostgreSQL
echo "Обновление пакетов и установка PostgreSQL..."
sudo apt update
sudo apt install -y postgresql postgresql-contrib

# 2. Запуск сервиса
echo "Запуск службы PostgreSQL..."
sudo systemctl start postgresql
sudo systemctl enable postgresql

# 3. Создание базы данных и пользователя
# Мы используем 'sudo -u postgres', чтобы выполнить команды от имени суперпользователя БД
echo "Создание пользователя $DB_USER и базы данных $DB_NAME..."

sudo -u postgres psql <<EOF
-- Создание пользователя
CREATE USER $DB_USER WITH PASSWORD '$DB_PASS';

-- Создание базы данных
CREATE DATABASE $DB_NAME OWNER $DB_USER;

-- Выдача прав (на всякий случай для существующих схем)
GRANT ALL PRIVILEGES ON DATABASE $DB_NAME TO $DB_USER;
EOF

echo "Готово! База данных '$DB_NAME' создана для пользователя '$DB_USER'."



# 1. Получаем пути к файлам конфигурации через psql
# Это надежнее, чем угадывать путь (например, /etc/postgresql/16/main/...)
PG_CONF=$(sudo -u postgres psql -t -P format=unaligned -c "show config_file")
PG_HBA=$(sudo -u postgres psql -t -P format=unaligned -c "show hba_file")

echo "Настройка postgresql.conf: $PG_CONF"
echo "Настройка pg_hba.conf: $PG_HBA"

# 2. Включаем прослушивание всех IP (* вместо localhost)
# Ищем строку с listen_addresses, раскомментируем и ставим '*'
sudo sed -i "s/^#\?listen_addresses\s*=.*/listen_addresses = '*'/" "$PG_CONF"
echo "listen_addresses = '*'" >> $PG_CONF

# 3. Разрешаем подключения в pg_hba.conf
# Добавляем правила для IPv4 (0.0.0.0/0) и IPv6 (::/0) в конец файла
# Используем метод md5 (или scram-sha-256 для новых версий) для безопасности
if ! grep -q "0.0.0.0/0" "$PG_HBA"; then
    echo "host    all             all             0.0.0.0/0               md5" | sudo tee -a "$PG_HBA"
fi

if ! grep -q "::/0" "$PG_HBA"; then
    echo "host    all             all             ::/0                    md5" | sudo tee -a "$PG_HBA"
fi

# 4. Перезапуск для применения настроек
echo "Перезапуск PostgreSQL..."
sudo systemctl restart postgresql

echo "Готово! PostgreSQL теперь принимает подключения со всех IP."



    SHELL
  end
end